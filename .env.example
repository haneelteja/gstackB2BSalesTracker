# Copy to .env.local and fill in. For Vercel: Project → Settings → Environment Variables (set for Production + Preview), then redeploy.

# Supabase: Settings → API — Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase browser-safe key: use EITHER legacy anon JWT OR new publishable key (not both required)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only: service_role JWT OR new "secret" API key from the same API settings page
SUPABASE_SERVICE_ROLE_KEY=

ANTHROPIC_API_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Optional: WhatsApp outreach
THREESIXTY_MESSAGER_API_KEY=
THREESIXTY_MESSAGER_CHANNEL_ID=
